# OpenAI 兼容接口（可填 DeepSeek / Qwen / OpenAI 等）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# Tavily 搜索
TAVILY_API_KEY=tvly-xxx

# Jina Reader（可选，无 key 也能用但有限速）
JINA_API_KEY=

# Agent 预算
MAX_STEPS=10
MAX_REFLECT_ROUNDS=2
MAX_CLARIFY_ROUNDS=2
TOKEN_BUDGET=120000
CONTEXT_TOKEN_LIMIT=45000
